{
  "name": "@yasmro/ui",
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.0",
  "description": "Design system with CSS variants and React components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./core/tokens": {
      "import": "./dist/core/tokens/index.css",
      "require": "./dist/core/tokens/index.css"
    },
    "./themes/default": {
      "import": "./dist/themes/default/index.css",
      "require": "./dist/themes/default/index.css"
    },
    "./themes/seasonal": {
      "types": "./dist/themes/seasonal/index.d.ts",
      "import": "./dist/themes/seasonal/index.js",
      "require": "./dist/themes/seasonal/index.cjs"
    },
    "./themes/seasonal/themes.css": {
      "import": "./dist/themes/seasonal/themes.css",
      "require": "./dist/themes/seasonal/themes.css"
    },
    "./variants": {
      "types": "./dist/variants/index.d.ts",
      "import": "./dist/variants/index.js",
      "require": "./dist/variants/index.cjs"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs"
    },
    "./components/lv1": {
      "types": "./dist/components/lv1/index.d.ts",
      "import": "./dist/components/lv1/index.js",
      "require": "./dist/components/lv1/index.cjs"
    },
    "./components/lv2": {
      "types": "./dist/components/lv2/index.d.ts",
      "import": "./dist/components/lv2/index.js",
      "require": "./dist/components/lv2/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup && pnpm build:css",
    "build:css": "mkdir -p dist/core/tokens dist/themes/default dist/themes/seasonal && cp src/core/tokens/*.css dist/core/tokens/ && cp src/themes/default/*.css dist/themes/default/ && cp src/themes/seasonal/*.css dist/themes/seasonal/",
    "build:storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "jsdom": "24",
    "lightningcss": "^1.28.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.7",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yasmro/yasmro-ui.git"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "tailwind",
    "cva"
  ]
}
